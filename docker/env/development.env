# Server configuration
ENVIRONMENT=development
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Database configuration
DATABASE_HOST=cockroachdb
DATABASE_PORT=26257
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_DBNAME=inferoute
DATABASE_SSLMODE=disable

# RabbitMQ configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=inferoute
RABBITMQ_PASSWORD=Nightshade900!
RABBITMQ_VHOST=/


# Auth configuration
AUTH_HMACSECRET=your-hmac-secret-key
AUTH_TOKENDURATION=60 

# Internal Security
INTERNAL_API_KEY=klondikee  # Change this in production
INTERNAL_NETWORK_CIDR=172.18.0.0/16 # Docker network range

# Docker config
VIRTUAL_HOST=core.infereoute.com
LETSENCRYPT_HOST=core.infereoute.com
LETSENCRYPT_EMAIL=charles@inferoute.com


## CockcraochDB wiregaurd

# Server 1
WIREGUARD_IP=127.0.0.1
#COCKROACH_JOIN_IPS=10.0.0.1:26257

# Server 2
#WIREGUARD_IP=10.0.0.2
#COCKROACH_JOIN_IPS=10.0.0.1:26257,10.0.0.2:26257

# Traefik configuration
TRAEFIK_ROUTER_RULE_HOST=Host(`localhost`)
TRAEFIK_ROUTER_ENTRYPOINTS=web

