# Environment Configuration
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=26257
DB_USER=root
DB_PASSWORD=
DB_NAME=inferoute
DB_SSL_MODE=disable

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Service Ports
ORCHESTRATOR_PORT=8080
AUTH_SERVICE_PORT=8081
PROVIDER_MGMT_PORT=8082
PROVIDER_COMM_PORT=8083
PROVIDER_HEALTH_PORT=8084
GENERAL_API_PORT=8085

# Auth configuration
AUTH_HMACSECRET=your-hmac-secret-key
AUTH_TOKENDURATION=60 


# Internal Security
# Requests must include a valid X-Internal-Key header matching the INTERNAL_API_KEY environment variable
# Requests must come from an IP within the INTERNAL_NETWORK_CIDR range

INTERNAL_API_KEY=klondikee  # Change this in production
INTERNAL_NETWORK_CIDR=192.168.0.0/24 # Docker network range

# Cloudflare Configuration
CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_EMAIL=your-cloudflare-email
DOMAIN_CLOUDFLARE=tunnel.example.com

# Logging
LOG_LEVEL=debug 